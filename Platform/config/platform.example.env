# PinchBot Platform local example environment
# Copy this file to Platform/config/platform.env before starting the local platform stack.

PLATFORM_ADDR=127.0.0.1:18791
PLATFORM_PUBLIC_BASE_URL=http://127.0.0.1:18791

# Database
PLATFORM_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable
PLATFORM_RUNTIME_CONFIG_PATH=config/runtime-config.json

# Supabase auth bridge
PLATFORM_SUPABASE_URL=https://your-project-ref.supabase.co
PLATFORM_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
PLATFORM_SUPABASE_JWKS_URL=
PLATFORM_SUPABASE_JWT_SECRET=
PLATFORM_SUPABASE_AUDIENCE=authenticated

# Admin bootstrap
PLATFORM_ADMIN_EMAILS=admin@example.com

# Payments
PLATFORM_PAYMENT_PROVIDER=manual
PLATFORM_EASYPAY_BASE_URL=
PLATFORM_EASYPAY_PID=
PLATFORM_EASYPAY_KEY=
PLATFORM_EASYPAY_TYPE=alipay
PLATFORM_ALIMPAY_BASE_URL=
PLATFORM_ALIMPAY_PID=
PLATFORM_ALIMPAY_KEY=
PLATFORM_ALIMPAY_TYPE=alipay

# Optional inline runtime seed JSON. Leave empty when using Platform/config/runtime-config.json.
PLATFORM_OFFICIAL_ROUTES_JSON=
PLATFORM_OFFICIAL_MODELS_JSON=
PLATFORM_PRICING_RULES_JSON=
PLATFORM_AGREEMENTS_JSON=

# Replace runtime config placeholders before local smoke testing:
# - replace-with-your-upstream-api-key

